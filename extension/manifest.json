{
  "manifest_version": 3,
  "name": "Manassas Bill Downloader",
  "version": "1.0.0",
  "description": "Download all City of Manassas utility bill PDFs from InvoiceCloud in one click.",
  "permissions": ["downloads", "activeTab", "scripting", "storage"],
  "host_permissions": ["*://*.invoicecloud.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Download Manassas Bills",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.invoicecloud.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
